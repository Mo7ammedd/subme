# --- Frontend (Vite) -----------------------------------------------------
# Base URL for the backend API. Leave blank to use the current origin —
# that works in dev (vite proxies /api to :3001) and in production when
# the frontend and backend are served from the same host.
# Set this when the frontend is deployed separately (e.g. static CDN):
#   VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# --- Backend (Express) ---------------------------------------------------
# Port the express server listens on. Default 3001.
PORT=3001

# Comma-separated list of origins allowed to call the API. Use "*" to allow
# any origin (default). Lock this down once the frontend's URL is known:
#   ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
ALLOWED_ORIGINS=*

# TMDB v4 Bearer token. A working default is baked into server/tmdbClient.js,
# but override it here to use your own token (recommended for production).
# TMDB_BEARER=

# Optional TMDB tuning
# TMDB_BASE_URL=https://api.themoviedb.org/3
# TMDB_MAX_CONCURRENT=6
# TMDB_MAX_RETRIES=4
# TMDB_RETRY_BASE_MS=300
